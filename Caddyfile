# Add this block to your HOST Caddy config (e.g. /etc/caddy/Caddyfile).
# Port 80/443 is already used on this server, so Caddy runs on the host — not in Docker.
# The RPM app container listens on localhost:9098.

cad.sisgain.ae {
	encode gzip zstd

	reverse_proxy localhost:9098 {
		health_uri /
		health_interval 30s
		health_timeout 5s
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}
}
